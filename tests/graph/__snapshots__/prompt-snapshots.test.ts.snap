exports[`buildGraphStateBlock with termination terminated (max_iterations, loopCounters, reason set) 1`] = `
"<collaboration_state>
  <status>exhausted</status>
  <frontier>reviewer</frontier>
  <completed>coder</completed>
  <iteration>5/3</iteration>
  <termination_reason>max_iterations</termination_reason>
  <loop_iterations group="coder,reviewer">5</loop_iterations>
  <next_action>Workflow terminated (reason: max_iterations) — synthesize the best final result from the completed agents' work</next_action>
</collaboration_state>"
`;

