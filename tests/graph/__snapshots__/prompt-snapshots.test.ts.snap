// Bun Snapshot v1, https://bun.sh/docs/test/snapshots

exports[`buildCollaborationBlock review-loop 2-agent (coder, reviewer) 1`] = `
"<collaboration_graph>
<topology>review-loop</topology>
<routing>
  Step 1: Dispatch initial work to Coder using task(subagent_type="coder", ...)
  Step 2: Collect Coder's output and dispatch to Reviewer using task(subagent_type="reviewer", prompt="[previous agent's full output]", ...)
  After the final agent responds, evaluate the result. If quality is insufficient, Reviewer may send work back to Coder by dispatching again with task(subagent_type="coder", prompt="[revision notes + previous output]", ...).
</routing>
<exit_conditions>
The graph completes when: the final result meets quality criteria and exits, OR max 3 iteration(s) reached.
</exit_conditions>
<routing_rules>
- NEVER do specialist work yourself. Always dispatch via task().
- Never call more than one specialist in a single step.
- Always pass the previous step's context and output when dispatching the next step.
</routing_rules>
</collaboration_graph>"
`;

exports[`buildCollaborationBlock review-loop 3-agent (writer, editor, publisher) 1`] = `
"<collaboration_graph>
<topology>review-loop</topology>
<routing>
  Step 1: Dispatch initial work to Writer using task(subagent_type="writer", ...)
  Step 2: Collect Writer's output and dispatch to Editor using task(subagent_type="editor", prompt="[previous agent's full output]", ...)
  Step 3: Collect Editor's output and dispatch to Publisher using task(subagent_type="publisher", prompt="[previous agent's full output]", ...)
  After the final agent responds, evaluate the result. If quality is insufficient, Publisher may send work back to Writer by dispatching again with task(subagent_type="writer", prompt="[revision notes + previous output]", ...).
</routing>
<exit_conditions>
The graph completes when: the final result meets quality criteria and exits, OR max 5 iteration(s) reached.
</exit_conditions>
<routing_rules>
- NEVER do specialist work yourself. Always dispatch via task().
- Never call more than one specialist in a single step.
- Always pass the previous step's context and output when dispatching the next step.
</routing_rules>
</collaboration_graph>"
`;

exports[`buildCollaborationBlock star 3-agent (frontend, backend, devops) 1`] = `
"<collaboration_graph>
<topology>star</topology>
<routing>
Dispatch work to each specialist in sequence (V1 limitation — parallel dispatch not supported):

  Step 1: Dispatch to Frontend using task(subagent_type="frontend", ...)
  Step 2: Dispatch to Backend using task(subagent_type="backend", ...)
  Step 3: Dispatch to DevOps using task(subagent_type="devops", ...)

  Collect all outputs. The combined results from all agents complete the workflow.
</routing>
<exit_conditions>
The graph completes when: all agents have returned their outputs, OR max 0 iteration(s) reached.
</exit_conditions>
<routing_rules>
- NEVER do specialist work yourself. Always dispatch via task().
- Never call more than one specialist in a single step.
</routing_rules>
</collaboration_graph>"
`;

exports[`buildCollaborationBlock custom flow with back-edge (researcher, writer, editor) 1`] = `
"<collaboration_graph>
<topology>custom</topology>
<routing>
  The orchestrator dispatches initial work to: Researcher.
  Use task(subagent_type="<agent-id>", ...) to dispatch to each.

  Agent-to-agent transitions: Researcher → Writer, Writer → Editor, Editor → Writer.

  Exit points: Editor. Their output completes the workflow.
</routing>
<exit_conditions>
The graph completes when: an exit-point agent returns their output, OR max 2 iteration(s) reached.
</exit_conditions>
<routing_rules>
- NEVER do specialist work yourself. Always dispatch via task().
- Never call more than one specialist in a single step.
- Always pass the previous step's context and output when dispatching the next step.
</routing_rules>
</collaboration_graph>"
`;

